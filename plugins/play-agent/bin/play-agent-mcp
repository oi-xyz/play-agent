#!/bin/sh

set -eu

minimum_node_major=20
launcher_directory=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
plugin_root=$(CDPATH= cd -- "${launcher_directory}/.." && pwd)
runtime="${plugin_root}/plugin-runtime/play-agent-mcp.mjs"
home=${HOME:-}

node_is_supported() {
  candidate=$1
  [ -x "$candidate" ] || return 1

  version=$("$candidate" --version 2>/dev/null) || return 1
  major=${version#v}
  major=${major%%.*}

  case "$major" in
    ''|*[!0-9]*) return 1 ;;
  esac

  [ "$major" -ge "$minimum_node_major" ]
}

if [ -n "${PLAY_AGENT_NODE:-}" ]; then
  if node_is_supported "$PLAY_AGENT_NODE"; then
    exec "$PLAY_AGENT_NODE" "$runtime" "$@"
  fi
  printf '%s\n' "Play Agent requires PLAY_AGENT_NODE to point to an executable Node.js ${minimum_node_major}+ binary." >&2
  exit 1
fi

path_node=$(command -v node 2>/dev/null || true)
if [ -n "$path_node" ] && node_is_supported "$path_node"; then
  exec "$path_node" "$runtime" "$@"
fi

for candidate in \
  "${FNM_DIR:-${home}/.local/share/fnm}/aliases/default/bin/node" \
  "${VOLTA_HOME:-${home}/.volta}/bin/node" \
  "${ASDF_DATA_DIR:-${home}/.asdf}/shims/node" \
  "${MISE_DATA_DIR:-${home}/.local/share/mise}/shims/node" \
  "/opt/homebrew/bin/node" \
  "/usr/local/bin/node" \
  "/usr/bin/node"
do
  if node_is_supported "$candidate"; then
    exec "$candidate" "$runtime" "$@"
  fi
done

for candidate in \
  "${home}"/.local/share/fnm/node-versions/*/installation/bin/node \
  "${NVM_DIR:-${home}/.nvm}"/versions/node/*/bin/node
do
  if node_is_supported "$candidate"; then
    exec "$candidate" "$runtime" "$@"
  fi
done

printf '%s\n' "Play Agent requires Node.js ${minimum_node_major}+." >&2
printf '%s\n' "Install Node.js, select a default fnm/nvm version, or set PLAY_AGENT_NODE to its executable path." >&2
exit 1
