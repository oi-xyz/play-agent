{
  "name": "play-agent",
  "version": "0.1.6",
  "private": true,
  "license": "Apache-2.0",
  "description": "A Codex Plugin for inspectable reasoning maps and independent review workflows.",
  "homepage": "https://github.com/oi-xyz/play-agent#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oi-xyz/play-agent.git"
  },
  "bugs": {
    "url": "https://github.com/oi-xyz/play-agent/issues"
  },
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "mcp": "tsx server/playAgentMcp.ts",
    "build": "npm run build:runtime && tsc --noEmit",
    "build:runtime": "esbuild server/playAgentMcp.ts --bundle --platform=node --format=esm --target=node20 --outfile=plugins/play-agent/plugin-runtime/play-agent-mcp.mjs",
    "docs:site": "node --import tsx scripts/generateUseCaseFixtures.ts --output dist/pages",
    "evaluate": "node --import tsx scripts/summarizeEvaluation.ts",
    "test": "NODE_ENV=test node --import tsx --test server/*.test.ts src/*.test.ts",
    "verify:plugin": "node scripts/smokePluginRuntime.mjs"
  },
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "esbuild": "^0.28.1",
    "tsx": "latest",
    "typescript": "latest"
  }
}
